<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');

:root {
  --paper: #FBF8F2;
  --paper-deep: #F3ECDD;
  --ink: #1B2A41;
  --ink-soft: #475569;
  --line: #E6DDC8;
  --card: #FFFFFF;

  /* category colors */
  --c-food: #C44536;       /* coral */
  --c-food-bg: #FBEAE6;
  --c-explore: #2F6B4F;    /* eucalyptus */
  --c-explore-bg: #E7F0EA;
  --c-shop: #8E5BA8;       /* plum */
  --c-shop-bg: #F1E7F5;
  --c-drive: #5B8AA6;      /* sky */
  --c-drive-bg: #E6EFF3;
  --c-home: #D9772C;       /* ochre */
  --c-home-bg: #FBEEE0;
  --c-booking: #B9912C;    /* gold */
  --c-booking-bg: #FAF1DD;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'Plus Jakarta Sans', sans-serif;
  line-height: 1.6;
  padding-bottom: 4rem;
}

/* texture */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: radial-gradient(circle, rgba(27,42,65,0.035) 1px, transparent 1px);
  background-size: 22px 22px;
  pointer-events: none;
  z-index: 0;
}

/* ===== HEADER ===== */
header {
  position: relative;
  padding: 3.2rem 1.5rem 1.8rem;
  text-align: center;
  background: linear-gradient(180deg, #FFFFFF 0%, var(--paper) 100%);
  border-bottom: 3px solid var(--ink);
  overflow: hidden;
}

header::after {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 220px; height: 220px;
  background: radial-gradient(circle, var(--c-home-bg) 0%, transparent 70%);
  border-radius: 50%;
}

header .edition {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--c-home);
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 1rem;
  position: relative;
  z-index: 1;
}

header .edition::before, header .edition::after {
  content: '✦';
  font-size: 0.6rem;
  opacity: 0.6;
}

header h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.3rem, 8vw, 3.2rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.05;
  position: relative;
}

header h1 em {
  font-style: italic;
  color: var(--c-explore);
}

header p.subtitle {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  color: var(--ink-soft);
  font-size: 1.05rem;
  margin: 0.4rem 0 1.4rem;
}

.header-stats {
  display: flex;
  justify-content: center;
  gap: 0.6rem;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

.hstat {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  font-weight: 600;
  padding: 0.45rem 0.9rem;
  border-radius: 30px;
  border: 1.5px solid var(--line);
  background: var(--card);
}

.hstat i { font-size: 0.8rem; }
.hstat.c-departure { border-color: var(--c-home); color: var(--c-home); }
.hstat.c-people { border-color: var(--c-explore); color: var(--c-explore); }
.hstat.c-distance { border-color: var(--c-drive); color: var(--c-drive); }
