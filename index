let currentActiveDay = 1;
let activeCategories = new Set(Object.keys(categoryMeta));
const loggedStops = new Set();

function initializeJournal() {
    generateCarouselPills();
    generateCategoryFilters();
    switchJournalDay(1);
    initializeTimer();
    initWeatherStrip();
    initPacking();
    updateProgressFab();

    document.getElementById('prevBtn').onclick = () => {
        if (currentActiveDay > 1) { currentActiveDay--; switchJournalDay(currentActiveDay); }
    };
    document.getElementById('nextBtn').onclick = () => {
        if (currentActiveDay < dynamicItinerary.length) { currentActiveDay++; switchJournalDay(currentActiveDay); }
    };
}

function generateCarouselPills() {
    const wrapper = document.getElementById('carouselContainer');
    wrapper.innerHTML = '';
    dynamicItinerary.forEach(d => {
        const pill = document.createElement('button');
        pill.className = `nav-pill ${d.day === currentActiveDay ? 'active' : ''}`;
        pill.innerHTML = `Day ${d.day}<span>${d.date.split(' ')[0]}</span>`;
        pill.onclick = () => {
            currentActiveDay = d.day;
            switchJournalDay(d.day);
        };
        wrapper.appendChild(pill);
    });
}

function generateCategoryFilters() {
    const wrapper = document.getElementById('categoryFilters');
    wrapper.innerHTML = '';
    Object.entries(categoryMeta).forEach(([key, meta]) => {
        const chip = document.createElement('div');
        chip.className = `cat-chip ${key} active`;
        chip.innerHTML = `<i class="fa-solid ${meta.icon}"></i> ${meta.label}`;
        chip.onclick = () => {
            if (activeCategories.has(key)) {
                activeCategories.delete(key);
                chip.classList.remove('active');
            } else {
                activeCategories.add(key);
                chip.classList.add('active');
            }
            renderDay(currentActiveDay);
        };
        wrapper.appendChild(chip);
    });
}

function switchJournalDay(targetDayId) {
    document.querySelectorAll('.nav-pill').forEach((p, idx) => {
        const isActive = idx + 1 === targetDayId;
        p.classList.toggle('active', isActive);
        if (isActive) p.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    });
    renderDay(targetDayId);
    window.scrollTo({ top: document.querySelector('.filter-bar').offsetHeight, behavior: 'smooth' });
}

function renderDay(targetDayId) {
    const selectedData = dynamicItinerary.find(d => d.day === targetDayId);
    if (!selectedData) return;

    document.getElementById('heroDate').innerText = selectedData.date;
    document.getElementById('heroTitle').innerText = selectedData.title;

    // day stats
    const visibleItems = selectedData.items.filter(ev => activeCategories.has(ev.tag));
    const mealCount = selectedData.items.filter(ev => ev.tag === 'food').length;
    const driveCount = selectedData.items.filter(ev => ev.tag === 'drive').length;
    document.getElementById('dayStats').innerHTML = `
        <div class="day-stat-box"><span class="num">${selectedData.items.length}</span><span class="lbl">Stops</span></div>
        <div class="day-stat-box highlight"><span class="num">${mealCount}</span><span class="lbl">Food Stops</span></div>
        <div class="day-stat-box highlight2"><span class="num">${selectedData.weather.split('·')[0].trim()}</span><span class="lbl">Forecast</span></div>
    `;

    const cardsTimeline = document.getElementById('nodesContainer');
    cardsTimeline.innerHTML = '';

    if (visibleItems.length === 0) {
        cardsTimeline.innerHTML = `<div style="text-align:center; padding:2rem; color:var(--ink-soft); font-style:italic;">No stops match the selected filters for this day.</div>`;
        return;
    }

    visibleItems.forEach((ev, idx) => {
        const stopKey = `d${targetDayId}_${idx}_${ev.time}`;
        const node = document.createElement('div');
        node.className = 'story-node';

        const meta = categoryMeta[ev.tag] || categoryMeta.home;

        let mapsAnchorSnippet = '';
        let copyAddrSnippet = '';
        if (ev.address) {
            const dynamicUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ev.address)}`;
            mapsAnchorSnippet = `<a href="${dynamicUrl}" target="_blank" class="action-btn"><i class="fa-solid fa-location-arrow"></i> Open Map</a>`;
            copyAddrSnippet = `<button class="action-btn copy-addr-btn" data-addr="${ev.address.replace(/"/g, '&quot;')}"><i class="fa-regular fa-copy"></i> Copy Address</button>`;
        }

        const durationSnippet = ev.duration ? `<div class="node-duration"><i class="fa-regular fa-clock"></i> ${ev.duration}</div>` : '';
        const tipSnippet = ev.tip ? `<div class="node-tip"><i class="fa-solid fa-circle-info"></i> ${ev.tip}</div>` : '';
        const factSnippet = ev.fact ? `<div class="node-fact"><i class="fa-solid fa-lightbulb"></i> Did you know? ${ev.fact}</div>` : '';
        const altSnippet = ev.alt ? `<div class="node-alt"><i class="fa-solid fa-cloud-rain"></i> ${ev.alt}</div>` : '';

        node.innerHTML = `
            <div class="node-marker">
                <div class="node-icon-circle ${ev.tag}"><i class="fa-solid ${ev.icon}"></i></div>
            </div>
            <div class="node-card ${ev.tag}" data-stopkey="${stopKey}">
                <div class="node-header">
                    <div class="node-time">${ev.time}</div>
                    <div class="node-tag ${ev.tag}">${meta.label}</div>
                </div>
                <div class="node-body">
                    ${ev.desc}
                    ${durationSnippet}
                    ${tipSnippet}
                    ${factSnippet}
                    ${altSnippet}
                    <div class="node-actions">
                        ${mapsAnchorSnippet}
                        ${copyAddrSnippet}
                    </div>
                </div>
            </div>
        `;
        cardsTimeline.appendChild(node);
    });

    // wire copy buttons
    cardsTimeline.querySelectorAll('.copy-addr-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const addr = btn.getAttribute('data-addr');
            navigator.clipboard?.writeText(addr).then(() => {
                btn.classList.add('copied');
                btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
                setTimeout(() => {
                    btn.classList.remove('copied');
                    btn.innerHTML = '<i class="fa-regular fa-copy"></i> Copy Address';
                }, 1500);
            });
            const card = btn.closest('.node-card');
            loggedStops.add(card.dataset.stopkey);
            updateProgressFab();
        });
    });

    cardsTimeline.querySelectorAll('.node-card').forEach(card => {
        card.addEventListener('click', (e) => {
            if (e.target.closest('.action-btn')) return;
            loggedStops.add(card.dataset.stopkey);
            card.style.opacity = '0.7';
            updateProgressFab();
        });
    });
}

function updateProgressFab() {
    document.getElementById('progressText').textContent = `${loggedStops.size} stops logged`;
}

function initWeatherStrip() {
    const selectedData = dynamicItinerary[0];
    const strip = document.getElementById('weatherStrip');
    strip.innerHTML = `<i class="fa-solid fa-cloud-sun"></i> WA Winter Outlook: <b>8–19°C</b> across the trip · Pack layers + a light rain shell · Day 2 has the highest rain chance (40%)`;
}

function initPacking() {
    const list = document.getElementById('packingList');
    list.innerHTML = packingItems.map((item, i) => `
        <div class="packing-item" data-idx="${i}">
            <div class="packing-checkbox"></div>
            <i class="fa-solid ${item.icon}" style="color:var(--c-explore); width:18px;"></i>
            <span class="plabel">${item.label}</span>
        </div>
    `).join('');

    list.querySelectorAll('.packing-item').forEach(el => {
        el.addEventListener('click', () => el.classList.toggle('checked'));
    });

    document.getElementById('packingToggle').addEventListener('click', () => {
        const isOpen = list.classList.toggle('open');
        document.getElementById('packingToggle').innerHTML = isOpen
            ? '<i class="fa-solid fa-xmark"></i> Close Packing Checklist'
            : '<i class="fa-solid fa-suitcase"></i> Open Smart Packing Checklist';
    });
}

function initializeTimer() {
    const launchDate = new Date("June 26, 2026 09:00:00").getTime();

    function updateClock() {
        const present = new Date().getTime();
        const remainder = launchDate - present;
        const clockEl = document.getElementById('clock');

        if (remainder < 0) {
            clockEl.innerHTML = '<i class="fa-solid fa-plane-departure"></i> Expedition is active';
            return;
        }
        const dayCounts = Math.floor(remainder / (1000 * 60 * 60 * 24));
        const label = dayCounts === 1 ? "Day" : "Days";
        clockEl.innerHTML = `<i class="fa-solid fa-plane-departure"></i> ${dayCounts} ${label} to Departure`;
    }

    updateClock();
    setInterval(updateClock, 60000);
}

window.onload = initializeJournal;
</script>
